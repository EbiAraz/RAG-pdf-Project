# Environment variables for HuggingFace and local development

# HuggingFace Hub (optional)
HF_TOKEN=

# Model settings (optional - overrides configs/settings.py)
# EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# GEN_MODEL=google/flan-t5-small

# Cache settings
HF_HOME=~/.cache/huggingface/

# Gradio settings
GRADIO_SHARE=False
GRADIO_SERVER_PORT=7860
